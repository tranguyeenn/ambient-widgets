{
  "name": "ambient-widgets",
  "description": "Tauri desktop shell + Vite/React/TypeScript UI. npm run dev = web only; npm run tauri dev = native window + dev server; npm run build = typecheck + production bundle to dist/; npm run tauri build = full app.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "open:dmg": "open src-tauri/target/release/bundle/dmg/*.dmg",
    "install:mac": "ditto \"src-tauri/target/release/bundle/macos/Ambient Widgets.app\" \"/Applications/Ambient Widgets.app\""
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
