# Copy to src-tauri/.env and set your Spotify app credentials.
# Redirect URI must match the value in the Spotify Developer Dashboard.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
GENIUS_ACCESS_TOKEN=your_genius_access_token_here
# Optional — avoids ZenQuotes rate limits (https://zenquotes.io/developers)
# ZENQUOTES_API_KEY=your_zenquotes_key_here
