{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "0.1.0",
  "identifier": "com.trangnguyen.orbit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "lyric",
        "title": "Lyrics",
        "url": "pages/lyrics.html",
        "create": true,
        "visible": true,
        "width": 400,
        "height": 200,
        "minWidth": 300,
        "minHeight": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 48,
        "y": 80
      },
      {
        "label": "calendar",
        "title": "Calendar",
        "url": "pages/calendar.html",
        "create": true,
        "visible": true,
        "width": 308,
        "height": 348,
        "minWidth": 260,
        "minHeight": 280,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 520,
        "y": 80
      },
      {
        "label": "weather",
        "title": "Weather",
        "url": "pages/weather.html",
        "create": true,
        "visible": true,
        "width": 160,
        "height": 160,
        "minWidth": 112,
        "minHeight": 112,
        "maxWidth": 480,
        "maxHeight": 480,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 360,
        "y": 80
      },
      {
        "label": "welcome",
        "title": "Welcome",
        "url": "pages/welcome.html",
        "create": true,
        "visible": false,
        "width": 900,
        "height": 640,
        "minWidth": 400,
        "minHeight": 400,
        "center": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": false,
        "shadow": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost https://api.open-meteo.com https://api.bigdatacloud.net https://dummyjson.com http://localhost:1420 ws://localhost:1420",
        "img-src": "'self' asset: http://asset.localhost blob: data: https://i.scdn.co",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
