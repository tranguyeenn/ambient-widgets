{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ambient Widgets",
  "version": "0.1.0",
  "identifier": "com.trangnguyen.ambient-widgets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "lyric",
        "title": "Lyrics",
        "url": "pages/lyrics.html",
        "create": true,
        "width": 400,
        "height": 200,
        "minWidth": 300,
        "minHeight": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 48,
        "y": 80
      },
      {
        "label": "calendar",
        "title": "Calendar",
        "url": "pages/calendar.html",
        "width": 308,
        "height": 348,
        "minWidth": 260,
        "minHeight": 280,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 520,
        "y": 80
      },
      {
        "label": "weather",
        "title": "Weather",
        "url": "pages/weather.html",
        "create": true,
        "width": 160,
        "height": 160,
        "minWidth": 112,
        "minHeight": 112,
        "maxWidth": 480,
        "maxHeight": 480,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "x": 360,
        "y": 80
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
