{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions shared by all Orbit webviews (lyric, calendar, weather, welcome).",
  "windows": ["lyric", "calendar", "weather", "welcome"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-center",
    "core:window:allow-set-focus",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-fullscreen",
    "core:window:allow-start-dragging",
    "opener:default",
    "allow-get-current-lyric",
    "allow-get-now-playing-track",
    "allow-spotify-login",
    "allow-spotify-is-authenticated",
    "window-state:default"
  ]
}
