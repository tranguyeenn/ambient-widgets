{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions shared by all widget webviews (lyric, calendar, …).",
  "windows": ["lyric", "calendar"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "allow-get-current-lyric",
    "allow-get-now-playing-track",
    "allow-fetch-zen-quote",
    "allow-spotify-login",
    "allow-spotify-is-authenticated",
    "window-state:default"
  ]
}
